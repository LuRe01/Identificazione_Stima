<?xml version="1.0" encoding="utf-8"?>
<chart id="102">
  <P Name="name">Dinamica Elicottero1/Dinamica Elicottero 2DOF</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">102</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">6</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">102</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function q_dot_dot = fcn(q, q_dot, tau, params)

alpha = q(1);
alpha_dot = q_dot(1);
beta = q(2);
beta_dot = q_dot(2);

% Costruzione Momento di Inerzia di Yaw (Variabile con angolo di pitch)
J_beta = params.J_y * sin(alpha)^2 + (params.J_z + params.m * params.l^2) * cos(alpha)^2 + params.I_b;

% Matrice di Inerzia
M = [params.J_alpha 0; 0 J_beta];

% Vettore dei termini non lineari (raccoglie attriti viscosi e forza di gravità)
n = [params.c_alpha * alpha_dot + params.m * params.g * params.l * sin(alpha); params.c_beta * beta_dot];

% Vettore delle Forze / Coppie generalizzate
B = [params.l * cos(beta), params.epsilon_p * params.l * sin(beta); params.epsilon_y * params.l * sin(alpha), params.l * cos(alpha)];

% Dinamica Inversa
q_dot_dot = M \ (B * tau - n);






</P>
      </eml>
    </state>
    <data SSID="4" name="q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="q_dot">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="tau">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="q_dot_dot">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="params">
      <P Name="scope">PARAMETER_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">102</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">102</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
    </junction>
  </Children>
</chart>

__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_28.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="28">
  <P Name="name">EKF/PREDIZIONE</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">28</P>
  <P Name="ssIdHighWaterMark">12</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">1</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Predizione</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">28</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [X_hat_pred, P_pred, F] = Predizione(X_hat, u, P, params)
    % PREDIZIONE EKF - Modello con Rumore di Attuazione sui Motori
    
    %% 1. Lettura dello Stato e Ingressi
    alpha     = X_hat(1);
    alpha_dot = X_hat(2);
    beta      = X_hat(3);
    beta_dot  = X_hat(4);
    
    F1 = u(1);
    F2 = u(2);
    
    %% 2. Estrazione Parametri Fisici
    m  = params.m;       l  = params.l;       g  = params.g;
    Ja = params.J_alpha; Jy = params.J_y;     Jz = params.J_z;
    Ib = params.I_b;     ca = params.c_alpha; cb = params.c_beta;
    ep = params.epsilon_p;   ey = params.epsilon_y;   
    dt = params.st;
    
    %% 3. Matrice di Covarianza del Rumore di Processo (Q)
    % Q è 2x2. Contiene la varianza del rumore dei motori EMAX MT2204
    % param.sigma_F = 0.05 [Newton]
    Q = [params.sigma_F^2, 0;
         0,               params.sigma_F^2];

    %% 4. MODELLO DINAMICO NON LINEARE
    J_beta = Jy * sin(alpha)^2 + (Jz + m*l^2) * cos(alpha)^2 + Ib;
    
    alpha_ddot = (-ca * alpha_dot - m * g * l * sin(alpha) + ...
                   l * F1 * cos(beta) + ep * l * F2 * sin(beta)) / Ja;
                   
    beta_ddot  = (-cb * beta_dot + l * F2 * cos(alpha) + ...
                   ey * l * F1 * sin(alpha)) / J_beta;

    %% 5. PREDIZIONE DELLO STATO (Eulero)
    X_hat_pred = [alpha     + dt * alpha_dot;
                  alpha_dot + dt * alpha_ddot;
                  beta      + dt * beta_dot;
                  beta_dot  + dt * beta_ddot];

    %% 6. CALCOLO JACOBIANA DI PROCESSO (A) -&gt; F = I + A*dt
    % Derivate per la riga 2 (alpha_ddot)
    A21 = (-m * g * l * cos(alpha)) / Ja;
    A22 = -ca / Ja;
    A23 = (-l * F1 * sin(beta) + ep * l * F2 * cos(beta)) / Ja;
    A24 = 0;
    
    % Derivate per la riga 4 (beta_ddot)
    N = -cb * beta_dot + l * F2 * cos(alpha) + ey * l * F1 * sin(alpha);
    D_den = J_beta;
    dN_dalpha = -l * F2 * sin(alpha) + ey * l * F1 * cos(alpha);
    dD_dalpha = 2 * Jy * sin(alpha) * cos(alpha) - 2 * (Jz + m*l^2) * cos(alpha) * sin(alpha);
    
    A41 = (D_den * dN_dalpha - N * dD_dalpha) / (D_den^2);
    A42 = 0;
    A43 = 0;
    A44 = -cb / D_den;
    
    % Assemblaggio e discretizzazione
    A = [  0,   1,   0,   0;
         A21, A22, A23, A24;
           0,   0,   0,   1;
         A41, A42, A43, A44];
         
    F = eye(4) + A * dt;
    
    %% 7. CALCOLO JACOBIANA DEI DISTURBI (D)
    % Rappresenta l&apos;impatto di 1 Newton di errore del motore sulle accelerazioni.
    % La matrice è 4x2 perché mappa 2 rumori su 4 stati.
    
    d_alpha_ddot_w1 = (l * cos(beta)) / Ja;
    d_alpha_ddot_w2 = (ep * l * sin(beta)) / Ja;
    
    d_beta_ddot_w1  = (ey * l * sin(alpha)) / J_beta;
    d_beta_ddot_w2  = (l * cos(alpha)) / J_beta;
    
    D = [0,                         0;
         d_alpha_ddot_w1 * dt,      d_alpha_ddot_w2 * dt;
         0,                         0;
         d_beta_ddot_w1 * dt,       d_beta_ddot_w2 * dt];
         
    %% 8. PREDIZIONE DELLA COVARIANZA
    % Diffusione dell&apos;incertezza dei motori negli stati tramite la matrice D
    P_pred = F * P * F&apos; + D * Q * D&apos;;
    
end</P>
      </eml>
    </state>
    <data SSID="6" name="X_hat">
