__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_71.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="71">
  <P Name="name">UKF/UKF Predizione</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">71</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">4</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_Predizione</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">71</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [X_hat_pred, P_pred] = UKF_Predizione(X_hat,u, params, P)

lambda = params.lambda;
n = params.n;

n_state = params.n_state;

% Estrazione parametri

m = params.m;   J_a = params.J_alpha;   l = params.l;
g = params.g;   c_a = params.c_alpha;   c_b = params.c_beta;
e_p = params.epsilon_p;     e_y = params.epsilon_y;

F_1 = u(1);
F_2 = u(2);

% Inizializzazione vettore sigma_points
sigma_points = zeros(n, 2*n + 1);

Q = diag([params.sigma_F^2, params.sigma_F^2]);

P_a = blkdiag(P, Q);

% Definizione stato aumentato
X_a = [X_hat; zeros(params.n_input, 1)];

% 1. Decomposizione ai Valori Singolari (SVD)
[U, S, ~] = svd(P_a); 

% 2. Protezione Numerica Assoluta: 
% Trasforma eventuali autovalori microscopici negativi in zero
S_positiva = max(S, 0); 

% 3. Calcolo della Radice di Matrice
GAMMA = U * sqrt(S_positiva);

% Estrazione Sigma-points(da -n ad n)
for i =-n:n
    idx = i + n + 1;
    if i == 0      
        sigma_points(:, idx) = X_a;       % Sigma-point centrale
    elseif i &gt; 0
        sigma_points(:, idx) = X_a + sqrt(n + lambda) * GAMMA(:, i);
    elseif i &lt; 0
        sigma_points(:, idx) = X_a - sqrt(n + lambda) * GAMMA(:, abs(i));
    end
end


%--------------------------------------------------------------------------
% PROPAGAZIONE SIGMA-POINTS
%--------------------------------------------------------------------------

sigma_points_pred = zeros(n_state, 2*n + 1);

dt = params.st;

for i = 1:(2*n + 1)

    % Estrazione Stato
    alpha = sigma_points(1, i);
    alpha_dot = sigma_points(2, i);
    beta = sigma_points(3, i);
    beta_dot = sigma_points(4, i);

    % Estrazione rumore di attuazione
    w_1 = sigma_points(5, i);
    w_2 = sigma_points(6, i);

    F_1_noise = F_1 + w_1;
    F_2_noise = F_2 + w_2;


    % Dinamica del sistema
    J_beta = params.J_y * sin(alpha)^2 + (params.J_z + params.m * params.l^2) * cos(alpha)^2 + params.I_b;

    alpha_dot_dot = 1/J_a * (-c_a * alpha_dot - m* g * l * sin(alpha) + l * F_1_noise * cos(beta) + e_p * l * F_2_noise * sin(beta));
    beta_dot_dot = 1/J_beta * (-c_b * beta_dot + l * F_2_noise * cos(alpha) + e_y * l * F_1_noise * sin(alpha));
    

    % Eulero:
    sigma_points_pred(1, i) = alpha + dt * alpha_dot;
    sigma_points_pred(2, i) = alpha_dot + dt * alpha_dot_dot;
    sigma_points_pred(3, i) = beta + dt * beta_dot;
    sigma_points_pred(4, i) = beta_dot + dt * beta_dot_dot;

end



% Predizione
X_hat_pred = zeros(4, 1);
for i = 1:(2*n + 1)
    X_hat_pred = X_hat_pred + params.Wm(i) * sigma_points_pred(:, i);
end

P_pred = zeros(4, 4);

for i = 1:(2*n + 1)
    P_pred = P_pred + params.Wc(i) * (sigma_points_pred(:, i) - X_hat_pred) * (sigma_points_pred(:, i) - X_hat_pred)&apos;;
end

end

</P>
      </eml>
    </state>
    <data SSID="4" name="X_hat">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="params">
      <P Name="scope">PARAMETER_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="X_hat_pred">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="P">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="P_pred">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">71</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">71</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
    </junction>
  </Children>
</chart>

__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_82.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="82">
  <P Name="name">UKF/UKF Correzione</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">82</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">18</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">5</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_Correzione</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">82</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [X_hat, P, e_acc,e_magn,flag_acc, flag_magn] = UKF_Correzione(X_hat_pred, P_pred, y_acc_raw, y_magn_raw, params, M_0, MAHALANOBIS, m_treshold, t)
% CORREZIONE UKF, conviene sfruttare il fatto che il rumore di misura è
% additivo (in questo caso non avrò lo stato aumentato con i rumori di
% misura)

n_state = params.n_state;
lambda = params.lambda_c;
g = params.g;
dt = params.st;

% Pre-allocazione (se nessuna misura è disponibile, rimango con la
% stima predetta)
P = P_pred;
X_hat = X_hat_pred;

% Uscite sensori
y_acc = y_acc_raw(1);
t_acc = y_acc_raw(2);

y_magn = y_magn_raw(1:2);
t_magn = y_magn_raw(3);

% Inizializzazione vettore sigma_points
sigma_points = zeros(n_state, 2*n_state + 1);

% 1. Decomposizione ai Valori Singolari (SVD)
[U, S, ~] = svd((P_pred + P_pred&apos;)/2); 

% 2. Protezione Numerica Assoluta: 
% Trasforma eventuali autovalori microscopici negativi in zero
S_positiva = max(S, 0); 

% 3. Calcolo della Radice di Matrice
GAMMA = U * sqrt(S_positiva);

% Estrazione Sigma-points(da -n_state ad n_state)
for i =-n_state:n_state
    idx = i + n_state + 1;
    if i == 0      
        sigma_points(:, idx) = X_hat_pred;       % Sigma-point centrale
    elseif i &gt; 0
        sigma_points(:, idx) = X_hat_pred + sqrt(n_state + lambda) * GAMMA(:, i);
    elseif i &lt; 0
        sigma_points(:, idx) = X_hat_pred - sqrt(n_state + lambda) * GAMMA(:, abs(i));
    end
end

%--------------------------------------------------------------------------
% PROPAGAZIONE ATTRAVERSO I SENSORI (TRASFORMATA UNSCENTED)
%--------------------------------------------------------------------------
Y_points = zeros(3, 2*n_state + 1);
for i = 1:(2*n_state +1)

    alpha = sigma_points(1, i);
    beta = sigma_points(3, i);

    % Modello di osservazione
    Y_points(1, i) = g * sin(alpha);
    Y_points(2, i) = M_0 * cos(beta);
    Y_points(3, i) = -M_0 * sin(beta);

end

% Media
y_hat = zeros(3, 1);
for i = 1:(2*n_state + 1)
    y_hat = y_hat + params.Wm_c(i) * Y_points(:, i);
end

% Covarianza
P_yy = zeros(3, 3);
P_xy = zeros(n_state, 3);
for i = 1:(2*n_state + 1)
    P_yy = P_yy + params.Wc_c(i) * ((Y_points(:, i) - y_hat) * (Y_points(:, i) - y_hat)&apos;);
    P_xy = P_xy + params.Wc_c(i) * ((sigma_points(:, i) - X_hat_pred) * (Y_points(:, i) - y_hat)&apos;);
end


%--------------------------------------------------------------------------
% Calcolo delle distanze di mahalanobis per i singoli sensori
%--------------------------------------------------------------------------

e = [y_acc; y_magn] - y_hat;

R = diag([params.R_acc, params.R_magn, params.R_magn]);

% Accelerometro
e_acc = e(1);
R_acc = R(1, 1);
S_acc = P_yy(1, 1) + R_acc;     % Sfrutto rumore additivo
mahalanobis_acc = sqrt(e_acc&apos; / S_acc * e_acc);

% Magnetometro
e_magn = e(2:3);
R_magn = R(2:3, 2:3);
S_magn = P_yy(2:3, 2:3) + R_magn;
mahalanobis_magn = sqrt(e_magn&apos; / S_magn * e_magn);

% Verifica della disponibilità delle misure
if MAHALANOBIS
    flag_acc = (mahalanobis_acc &lt;= m_treshold) &amp;&amp; (t_acc &lt;= t) &amp;&amp; (t - dt &lt; t_acc);
    flag_magn = (mahalanobis_magn &lt;= m_treshold) &amp;&amp; (t_magn &lt;= t) &amp;&amp; (t - dt &lt; t_magn);
else
    flag_acc =  (t_acc &lt;= t) &amp;&amp; (t - dt &lt; t_acc);
    flag_magn = (t_magn &lt;= t) &amp;&amp; (t - dt &lt; t_magn);
end


% Costruzione delle matrici in base alle misure valide
% Entrambe le misure valide
if flag_acc &amp;&amp; flag_magn

    e_curr = e;
    S_curr = P_yy + R;
    P_xy_curr = P_xy;
    
elseif flag_acc     % Solo misura accelerometro disponibile
    e_curr = e_acc;
    S_curr = S_acc;
    P_xy_curr = P_xy(:, 1);

elseif flag_magn    % Solo misura magnetometro disponibile
    e_curr = e_magn;
    S_curr = S_magn;
    P_xy_curr = P_xy(:, 2:3);

else                % Nessuna misura disponibile
    return;
end

% CORREZIONE
% Guadagno di correzione
L = P_xy_curr / S_curr;

% x_k|k
X_hat = X_hat_pred + L * e_curr;

% P_k|k 
P = P_pred - L * S_curr * L&apos;;</P>
      </eml>
    </state>
    <data SSID="4" name="X_hat_pred">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="X_hat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
