__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_40.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="40">
  <P Name="name">Dinamica Elicottero/Dinamica Elicottero 2DOF</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">40</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">2</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">40</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function q_dot_dot = fcn(q, q_dot, tau, params)

alpha = q(1);
alpha_dot = q_dot(1);
beta = q(2);
beta_dot = q_dot(2);

% Costruzione Momento di Inerzia di Yaw (Variabile con angolo di pitch)
J_beta = params.J_y * sin(alpha)^2 + (params.J_z + params.m * params.l^2) * cos(alpha)^2 + params.I_b;

% Matrice di Inerzia
M = [params.J_alpha 0; 0 J_beta];

% Vettore dei termini non lineari (raccoglie attriti viscosi e forza di gravità)
n = [params.c_alpha * alpha_dot + params.m * params.g * params.l * sin(alpha); params.c_beta * beta_dot];

% Vettore delle Forze / Coppie generalizzate
B = [params.l * cos(beta), params.epsilon_p * params.l * sin(beta); params.epsilon_y * params.l * sin(alpha), params.l * cos(alpha)];

% Dinamica Inversa
q_dot_dot = M \ (B * tau - n);






</P>
      </eml>
    </state>
    <data SSID="4" name="q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="q_dot">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="tau">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="q_dot_dot">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="params">
      <P Name="scope">PARAMETER_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">40</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">40</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
    </junction>
  </Children>
</chart>

__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_50.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="50">
  <P Name="name">EKF/CORREZIONE</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">50</P>
  <P Name="ssIdHighWaterMark">26</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Correzione</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">50</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [X_hat, P, e, e_acc,e_magn, flag_acc,flag_magn] = Correzione(X_hat_pred, y_acc_raw, y_magn_raw, P_pred, params, t, MAHALANOBIS, M_0, m_treshold)
    % FUNZIONE DI CORREZIONE EKF 
    % Modello di osservazione: 
    % y_acc = gsin(alpha_k) + v_alpha_k
    % y_magn = [M_0*cos*(beta_k),-M_0*sin(beta_k)] + [v_beta_k, v_beta_k]

    g = params.g;
    dt = params.st;

    % Inizializzazione
    X_hat = X_hat_pred;
    P = P_pred;
    
    % Input (x_k|k-1)
    alpha = X_hat_pred(1); 
    beta = X_hat_pred(3);

    % Uscite Sensori
    t_acc = y_acc_raw(2);
    t_magn = y_magn_raw(3);
    y_acc = y_acc_raw(1);
    y_magn = y_magn_raw(1:2);

      
    % Covarianze errore di misura
    R = diag([params.R_acc, params.R_magn, params.R_magn]);
    
    % Matrice M = dh_k/dv_k  valutata in x_k|k-1
    M = eye(3);

    % Matrice H = dh_k/x_k valutata in x_k|k-1
    H = [g*cos(alpha), 0, 0, 0; ...
        0, 0, -M_0*sin(beta), 0; ...
        0, 0, -M_0*cos(beta), 0];

    % Innovazione
    e = [y_acc; y_magn] - [g*sin(alpha); M_0*cos(beta);-M_0*sin(beta)];

    % Calcolo delle singole distanze di mahalanobis
    H_acc = H(1, :);
    e_acc = e(1);
    M_acc = M(1, 1);
    R_acc = R(1, 1);
    S_acc = H_acc * P_pred * H_acc&apos; + M_acc * R_acc * M_acc&apos;;
    mahalanobis_acc = sqrt(e_acc&apos; / S_acc * e_acc);

    H_magn = H(2:3, :);
    e_magn = e(2:3);
    M_magn = M(2:3, 2:3);
    R_magn = R(2:3, 2:3);
    S_magn = H_magn * P_pred * H_magn&apos; + M_magn * R_magn * M_magn&apos;;
    mahalanobis_magn = sqrt(e_magn&apos; / S_magn * e_magn);

    % Verifica della disponibilità delle misure
    if MAHALANOBIS
        flag_acc = (mahalanobis_acc &lt;= m_treshold) &amp;&amp; (t_acc &lt;= t) &amp;&amp; (t - dt &lt; t_acc);
        flag_magn = (mahalanobis_magn &lt;= m_treshold) &amp;&amp; (t_magn &lt;= t) &amp;&amp; (t - dt &lt; t_magn);
    else
        flag_acc =  (t_acc &lt;= t) &amp;&amp; (t - dt &lt; t_acc);
        flag_magn = (t_magn &lt;= t) &amp;&amp; (t - dt &lt; t_magn);
    end

    % Costruzione delle matrici in base alle misure valide
    % Entrambe le misure valide
    if flag_acc &amp;&amp; flag_magn
        H_curr = H;
        e_curr = e;
        M_curr = M;
        R_curr = R;

    elseif flag_acc     % Solo misura accelerometro disponibile
        H_curr = H_acc;
        e_curr = e_acc;
        M_curr = M_acc;
        R_curr = R_acc;

    elseif flag_magn    % Solo misura magnetometro disponibile
        H_curr = H_magn;
        e_curr = e_magn;
        M_curr = M_magn;
        R_curr = R_magn;

    else                % Nessuna misura disponibile
        return;
    end

    % Covarianza dell&apos;innovazione
    S = H_curr * P_pred * H_curr&apos; + M_curr * R_curr * M_curr&apos;;

    % Guadagno di Correzione
    L = P_pred * H_curr&apos; / S;
    
    % Aggiornamento stato e covarianza
    X_hat = X_hat_pred + L * e_curr;
    % Forma di Joseph
    P = (eye(4) - L * H_curr) * P_pred * (eye(4) - L * H_curr)&apos; + L * R_curr * L&apos;;

end</P>
      </eml>
    </state>
    <data SSID="4" name="X_hat_pred">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_acc_raw">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="y_magn_raw">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="X_hat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="P_pred">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="P">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="params">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">3</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="13" name="t">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="14" name="MAHALANOBIS">
      <P Name="scope">PARAMETER_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="15" name="M_0">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">1</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="18" name="e">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="24" name="e_acc">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="26" name="e_magn">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="19" name="m_treshold">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">2</P>
